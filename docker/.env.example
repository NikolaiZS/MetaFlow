# MetaFlow Environment Variables Example

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key
SUPABASE_CONNECTION_STRING=Host=your-project.supabase.co;Port=5432;Database=postgres;Username=postgres;Password=your-password;SSL Mode=Require

# PostgreSQL (local)
POSTGRES_PASSWORD=your-secure-password

# Redis
REDIS_CONNECTION_STRING=localhost:6379

# JWT
JWT_SECRET=your-jwt-secret-key-at-least-32-characters-long

# SMTP/Email Service
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM_EMAIL=noreply@metaflow.com
SMTP_FROM_NAME=MetaFlow

# Email Service URL (for API integration)
EMAIL_SERVICE_URL=http://email-service:8080

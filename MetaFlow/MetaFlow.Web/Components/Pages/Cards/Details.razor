@page "/cards/{CardId:guid}"
@inject ApiServiceClient Api
@inject NavigationManager Navigate
@inject AppState State
@using MetaFlow.Contracts.Cards
@using MetaFlow.Contracts.Comments
@using MetaFlow.Contracts.Attachments

@if (card == null)
{
    <p>Loading...</p>
}
else
{
    <div class="container">
        <div class="mb-4">
             <h3>@card.Title</h3>
             <small class="text-muted">In column: @card.ColumnId</small>
        </div>

        @if (!string.IsNullOrEmpty(errorMessage))
        {
            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                @errorMessage
                <button type="button" class="btn-close" @onclick="() => errorMessage = null" aria-label="Close"></button>
            </div>
        }

        <div class="row">
            <div class="col-md-8">
                <!-- Description -->
                <div class="mb-4">
                     <h5>Description</h5>
                     <p>@card.Description</p>
                </div>
                
                <hr />

                <!-- Attachments -->
                <div class="mb-4">
                     <h5>
                         📎 Attachments 
                         @if (attachments != null && attachments.Count > 0)
                         {
                             <span class="badge bg-secondary ms-2">@attachments.Count</span>
                         }
                     </h5>
                     
                     @if (attachments != null && attachments.Count > 0)
                     {
                         <div class="row g-3 mb-3">
                             @foreach (var att in attachments)
                             {
                                 <div class="col-md-6 col-lg-4">
                                     <div class="card h-100 shadow-sm">
                                         @if (IsImage(att.FileName))
                                         {
                                             <img src="@att.FileUrl" class="card-img-top" alt="@att.FileName" style="height: 150px; object-fit: cover;" @onclick="() => OpenFile(att.FileUrl)" />
                                         }
                                         else
                                         {
                                             <div class="card-img-top bg-light d-flex align-items-center justify-content-center" style="height: 150px; cursor: pointer;" @onclick="() => OpenFile(att.FileUrl)">
                                                 <div class="text-center">
                                                     <i class="@GetFileIcon(att.FileName)" style="font-size: 3rem; color: #6c757d;"></i>
                                                     <div class="mt-2 small text-muted">@GetFileExtension(att.FileName)</div>
                                                 </div>
                                             </div>
                                         }
                                         <div class="card-body p-2">
                                             <h6 class="card-title text-truncate mb-1" title="@att.FileName" style="cursor: pointer;" @onclick="() => OpenFile(att.FileUrl)">
                                                 @att.FileName
                                             </h6>
                                             <small class="text-muted d-block">@FormatFileSize(att.FileSize)</small>
                                             <small class="text-muted d-block">by @att.UploadedByUsername • @att.UploadedAt.ToShortDateString()</small>
                                         </div>
                                         <div class="card-footer bg-transparent p-1">
                                             <div class="btn-group btn-group-sm w-100">
                                                 <button class="btn btn-outline-primary" @onclick="() => OpenFile(att.FileUrl)" title="Открыть">
                                                     <i class="bi bi-box-arrow-up-right"></i> Открыть
                                                 </button>
                                                 <button class="btn btn-outline-danger" @onclick="() => HandleDeleteAttachment(att.Id)" title="Удалить">
                                                     <i class="bi bi-trash"></i>
                                                 </button>
                                             </div>
                                         </div>
                                     </div>
                                 </div>
                             }
                         </div>
                     }

                     <!-- Upload Area -->
                     <div class="card p-3">
                         <h6 class="mb-3">
                             <i class="bi bi-cloud-upload"></i> Загрузить файл
                         </h6>
                         
                         @if (isUploading)
                         {
                             <div class="alert alert-info mb-3">
                                 <div class="d-flex align-items-center">
                                     <div class="spinner-border spinner-border-sm me-2" role="status">
                                         <span class="visually-hidden">Загрузка...</span>
                                     </div>
                                     <span>Загрузка: @uploadProgress</span>
                                 </div>
                             </div>
                         }

                         <div class="mb-3">
                             <InputFile OnChange="HandleFileSelected" multiple class="form-control" accept="image/*,.pdf,.doc,.docx,.xls,.xlsx,.txt,.zip,.rar" />
                             @if (selectedFiles?.Count > 0)
                             {
                                 <div class="mt-2">
                                     <small class="text-muted">Выбрано файлов: @selectedFiles.Count</small>
                                     <ul class="list-group list-group-flush mt-2">
                                         @foreach (var file in selectedFiles)
                                         {
                                             <li class="list-group-item d-flex justify-content-between align-items-center py-1 px-2">
                                                 <span>
                                                     <i class="@GetFileIcon(file.Name)"></i> 
                                                     @file.Name 
                                                     <small class="text-muted">(@FormatFileSize(file.Size))</small>
                                                 </span>
                                             </li>
                                         }
                                     </ul>
                                 </div>
                             }
                         </div>
                         
                         <button class="btn btn-primary btn-sm" @onclick="HandleUploadFiles" disabled="@(selectedFiles == null || selectedFiles.Count == 0 || isUploading)">
                             <i class="bi bi-upload"></i> Загрузить (@(selectedFiles?.Count ?? 0) файлов)
                         </button>
                     </div>
                </div>

                <hr />
                
                <!-- Comments -->
                <div class="mb-4">
                     <h5>Comments</h5>
                     @if (comments != null)
                     {
                         @foreach (var comm in comments)
                         {
                             <div class="card mb-2">
                                 <div class="card-body p-2">
                                     <div class="d-flex justify-content-between">
                                         <div>
                                            <strong>User @comm.Username</strong> <small class="text-muted">@comm.CreatedAt</small>
                                         </div>
                                         <div>
                                             @if (editingCommentId == comm.Id)
                                             {
                                                  <button class="btn btn-sm btn-link" @onclick="CancelEditComment">Cancel</button>
                                             }
                                             else
                                             {
                                                 <button class="btn btn-sm btn-link" @onclick="() => EditComment(comm)">Edit</button>
                                                 <button class="btn btn-sm btn-link text-danger" @onclick="() => HandleDeleteComment(comm.Id)">Delete</button>
                                             }
                                         </div>
                                     </div>
                                     
                                     @if (editingCommentId == comm.Id)
                                     {
                                         <EditForm Model="@editCommentModel" OnValidSubmit="HandleUpdateComment">
                                             <InputTextArea @bind-Value="editCommentModel.Content" class="form-control mb-2" />
                                             <button type="submit" class="btn btn-sm btn-primary">Save</button>
                                         </EditForm>
                                     }
                                     else
                                     {
                                         <p class="mb-1">@comm.Content</p>
                                     }
                                 </div>
                             </div>
                         }
                     }
                     
                     <div class="mt-3">
                         <EditForm Model="@commentModel" OnValidSubmit="HandleComment">
                             <DataAnnotationsValidator />
                             <div class="mb-2">
                                 <InputTextArea @bind-Value="commentModel.Content" placeholder="Write a comment..." class="form-control" />
                             </div>
                             <div class="mb-2">
                                 <InputFile OnChange="HandleCommentFileSelected" multiple />
                                 @if (commentFiles?.Count > 0)
                                 {
                                     <small class="text-muted">@($"{commentFiles.Count} file(s) selected")</small>
                                 }
                             </div>
                             <button type="submit" class="btn btn-sm btn-primary">Post Comment</button>
                         </EditForm>
                     </div>
                </div>
            </div>

            <div class="col-md-4">
                <div class="card">
                    <div class="card-header">Actions</div>
                    <div class="card-body">
                          <button class="btn btn-outline-primary w-100 mb-3" @onclick="ShowEditCard">Edit Details</button>
                          <div class="mb-3">
                              <label class="form-label">Priority</label>
                              <select class="form-select" @onchange="HandlePriorityChange" value="@card.Priority">
                                  <option value="low">Low</option>
                                  <option value="medium">Medium</option>
                                  <option value="high">High</option>
                                  <option value="urgent">Urgent</option>
                              </select>
                          </div>
                          <p>Due: @card.DueDate</p>
                         @if (card.IsArchived)
                         {
                             <button class="btn btn-warning w-100 mb-2" @onclick="HandleUnarchive">Unarchive</button>
                         }
                         else
                         {
                             <button class="btn btn-danger w-100 mb-2" @onclick="HandleArchive">Archive</button>
                         }
                         <button class="btn btn-outline-danger w-100" @onclick="HandleDelete">Delete</button>
                    </div>
                </div>
            </div>
        </div>
    </div>

    @if (showEditCardModal)
    {
        <div class="modal d-block" style="background: rgba(0,0,0,0.5)">
             <div class="modal-dialog">
                  <div class="modal-content">
                       <div class="modal-header">
                            <h5 class="modal-title">Edit Card</h5>
                            <button type="button" class="btn-close" @onclick="CancelEditCard"></button>
                       </div>
                       <div class="modal-body">
                           <EditForm Model="@updateCardModel" OnValidSubmit="HandleUpdateCardDetails">
                                <DataAnnotationsValidator />
                                <div class="mb-3">
                                    <label>Title</label>
                                    <InputText @bind-Value="updateCardModel.Title" class="form-control" />
                                </div>
                                <div class="mb-3">
                                    <label>Description</label>
                                    <InputTextArea @bind-Value="updateCardModel.Description" class="form-control" rows="5" />
                                </div>
                                <div class="mb-3">
                                    <label>Due Date</label>
                                    <InputDate @bind-Value="updateCardModel.DueDate" class="form-control" />
                                </div>
                                <button type="submit" class="btn btn-primary">Save Changes</button>
                           </EditForm>
                       </div>
                  </div>
             </div>
        </div>
    }
}

@code {
    [Parameter]
    public Guid CardId { get; set; }

    private CardResponse? card;
    private List<CommentResponse>? comments;
    private List<AttachmentResponse>? attachments;

    private CreateCommentViewModel commentModel = new();
    private List<IBrowserFile> commentFiles = new();
    private List<IBrowserFile>? selectedFiles;
    private bool isUploading = false;
    private string uploadProgress = "";

    private Guid? editingCommentId;
    private UpdateCommentViewModel editCommentModel = new();
    private string? errorMessage;

    private class UpdateCommentViewModel
    {
        public string Content { get; set; } = string.Empty;
    }

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private void HandleCommentFileSelected(InputFileChangeEventArgs e)
    {
        commentFiles = e.GetMultipleFiles().ToList();
    }

    private async Task LoadData()
    {
        card = await Api.GetCardAsync(CardId);
        if (card != null)
        {
             comments = await Api.GetCommentsAsync(CardId);
             attachments = await Api.GetAttachmentsAsync(CardId);
        }
    }

    private void HandleFileSelected(InputFileChangeEventArgs e)
    {
        selectedFiles = e.GetMultipleFiles().ToList();
        errorMessage = null;
    }

    private async Task HandleUploadFiles()
    {
        if (selectedFiles == null || selectedFiles.Count == 0) return;

        isUploading = true;
        uploadProgress = $"Загрузка 0 из {selectedFiles.Count} файлов...";
        StateHasChanged();

        var successCount = 0;
        var failedCount = 0;

        for (int i = 0; i < selectedFiles.Count; i++)
        {
            var file = selectedFiles[i];
            uploadProgress = $"Загрузка {i + 1} из {selectedFiles.Count}: {file.Name}...";
            StateHasChanged();

            try
            {
                var uploaded = await Api.UploadAttachmentFileAsync(CardId, file);
                if (uploaded != null)
                {
                    attachments ??= new();
                    attachments.Add(uploaded);
                    successCount++;
                }
                else
                {
                    failedCount++;
                    errorMessage = $"Не удалось загрузить файл: {file.Name}";
                }
            }
            catch (Exception ex)
            {
                failedCount++;
                errorMessage = $"Ошибка загрузки {file.Name}: {ex.Message}";
            }
        }

        uploadProgress = $"Загружено: {successCount} успешно, {failedCount} ошибок";
        selectedFiles = null;
        isUploading = false;
        StateHasChanged();
    }

    private void OpenFile(string fileUrl)
    {
        Navigate.NavigateTo(fileUrl, forceLoad: true);
    }

    private bool IsImage(string fileName)
    {
        var extension = Path.GetExtension(fileName).ToLowerInvariant();
        return extension is ".jpg" or ".jpeg" or ".png" or ".gif" or ".webp" or ".bmp" or ".svg";
    }

    private string GetFileIcon(string fileName)
    {
        var extension = Path.GetExtension(fileName).ToLowerInvariant();
        return extension switch
        {
            ".pdf" => "bi bi-file-earmark-pdf",
            ".doc" or ".docx" => "bi bi-file-earmark-word",
            ".xls" or ".xlsx" => "bi bi-file-earmark-excel",
            ".zip" or ".rar" => "bi bi-file-earmark-zip",
            ".txt" => "bi bi-file-earmark-text",
            ".jpg" or ".jpeg" or ".png" or ".gif" or ".webp" => "bi bi-file-earmark-image",
            ".mp4" or ".avi" or ".mov" => "bi bi-file-earmark-play",
            ".mp3" or ".wav" => "bi bi-file-earmark-music",
            _ => "bi bi-file-earmark"
        };
    }

    private string GetFileExtension(string fileName)
    {
        return Path.GetExtension(fileName).ToUpperInvariant().TrimStart('.');
    }

    private string FormatFileSize(long? bytes)
    {
        if (!bytes.HasValue || bytes.Value == 0) return "0 B";
        
        string[] sizes = { "B", "KB", "MB", "GB", "TB" };
        int order = 0;
        double size = bytes.Value;
        
        while (size >= 1024 && order < sizes.Length - 1)
        {
            order++;
            size /= 1024;
        }
        
        return $"{size:0.##} {sizes[order]}";
    }

    private async Task HandleComment()
    {
        var tempId = Guid.NewGuid();
        var tempComment = new CommentResponse(
            tempId, CardId, Guid.Empty, "You", null, null, commentModel.Content, false, false, DateTime.Now, DateTime.Now, new List<CommentResponse>());

        comments ??= new();
        comments.Add(tempComment);
        commentModel = new();
        StateHasChanged();

        var request = new CreateCommentRequest(tempComment.Content, null);
        var response = await Api.CreateCommentAsync(CardId, request);
        
        if (response != null)
        {
            var index = comments.FindIndex(c => c.Id == tempId);
            if (index != -1)
            {
                comments[index] = response;
            }
        }
        else
        {
             comments.Remove(tempComment);
             errorMessage = "Failed to post comment.";
        }

        if (response != null && commentFiles.Count > 0)
        {
            attachments ??= new();

            foreach (var file in commentFiles)
            {
                var uploaded = await Api.UploadAttachmentFileAsync(CardId, file);
                if (uploaded != null)
                {
                    attachments.Add(uploaded);
                }
                else
                {
                    errorMessage ??= "Failed to upload one or more attachments.";
                }
            }

            commentFiles.Clear();
        }
    }
    
    private void EditComment(CommentResponse comment)
    {
        editingCommentId = comment.Id;
        editCommentModel = new UpdateCommentViewModel { Content = comment.Content };
    }
    
    private void CancelEditComment()
    {
        editingCommentId = null;
        editCommentModel = new();
    }
    
    private async Task HandleUpdateComment()
    {
        if (editingCommentId == null) return;
        var commentId = editingCommentId.Value;
        var index = comments?.FindIndex(c => c.Id == commentId) ?? -1;
        if (index == -1) return;

        var originalComment = comments![index];
        var updatedComment = originalComment with { Content = editCommentModel.Content, IsEdited = true };

        comments[index] = updatedComment;
        editingCommentId = null;
        StateHasChanged();
        
        var request = new UpdateCommentRequest(editCommentModel.Content);
        var response = await Api.UpdateCommentAsync(CardId, commentId, request);
        
        if (response == null)
        {
            comments[index] = originalComment;
            errorMessage = "Failed to update comment.";
        }
    }

    private async Task HandleDeleteComment(Guid commentId)
    {
        var comment = comments?.FirstOrDefault(c => c.Id == commentId);
        if (comment == null) return;

        comments!.Remove(comment);
        StateHasChanged();

        var success = await Api.DeleteCommentAsync(CardId, commentId);
        if (!success)
        {
            comments.Add(comment);
            comments.Sort((a, b) => a.CreatedAt.CompareTo(b.CreatedAt));
            errorMessage = "Failed to delete comment.";
        }
    }

    private async Task HandleDeleteAttachment(Guid attachmentId)
    {
        var attachment = attachments?.FirstOrDefault(a => a.Id == attachmentId);
        if (attachment == null) return;

        attachments!.Remove(attachment);
        StateHasChanged();

        var success = await Api.DeleteAttachmentAsync(CardId, attachmentId);
        if (!success)
        {
            attachments.Add(attachment);
            errorMessage = "Failed to delete attachment.";
        }
    }

    private async Task HandleArchive()
    {
        if (card == null) return;
        
        card = card with { IsArchived = true };
        
        var success = await Api.ArchiveCardAsync(card.BoardId, CardId);
        if (!success)
        {
            card = card with { IsArchived = false };
            errorMessage = "Failed to archive card.";
        }
    }

    private async Task HandleUnarchive()
    {
        if (card == null) return;
        
        card = card with { IsArchived = false };

        var success = await Api.UnarchiveCardAsync(card.BoardId, CardId);
        if (!success)
        {
            card = card with { IsArchived = true };
            errorMessage = "Failed to unarchive card.";
        }
    }

    private async Task HandleDelete()
    {
        if (card == null) return;
        var success = await Api.DeleteCardAsync(card.BoardId, CardId);
        if (success)
        {
            Navigate.NavigateTo($"/boards/{card.BoardId}");
        }
    }

    private class UpdateCardViewModel
    {
        public string Title { get; set; } = string.Empty;
        public string? Description { get; set; }
        public string? Priority { get; set; }
        public string? Status { get; set; }
        public DateTime? DueDate { get; set; }
        public Guid? AssignedToId { get; set; }
    }

    private bool showEditCardModal = false;
    private UpdateCardViewModel updateCardModel = new();

    private void ShowEditCard()
    {
        if (card == null) return;
        updateCardModel = new UpdateCardViewModel
        {
            Title = card.Title,
            Description = card.Description,
            Priority = card.Priority,
            Status = card.Status,
            DueDate = card.DueDate,
            AssignedToId = card.AssignedToId
        };
        showEditCardModal = true;
    }

    private void CancelEditCard()
    {
        showEditCardModal = false;
    }

    private async Task HandleUpdateCardDetails()
    {
        if (card == null) return;
        
        var request = new UpdateCardRequest(
            updateCardModel.Title,
            updateCardModel.Description,
            updateCardModel.Priority,
            updateCardModel.Status,
            updateCardModel.DueDate,
            null,
            updateCardModel.AssignedToId
        );

        var originalCard = card with {};
        
        card = card with 
        { 
            Title = updateCardModel.Title,
            Description = updateCardModel.Description,
            Priority = updateCardModel.Priority ?? card.Priority,
            Status = updateCardModel.Status ?? card.Status,
            DueDate = updateCardModel.DueDate,
            AssignedToId = updateCardModel.AssignedToId
        };
        showEditCardModal = false;

        var updated = await Api.UpdateCardAsync(card.BoardId, CardId, request);
        if (updated == null)
        {
            card = originalCard;
            errorMessage = "Failed to update card details.";
            showEditCardModal = true;
        }
    }

    private async Task HandlePriorityChange(ChangeEventArgs e)
    {
        if (card == null) return;
        var newPriority = e.Value?.ToString();
        if (!string.IsNullOrEmpty(newPriority))
        {
            var originalPriority = card.Priority;
            card = card with { Priority = newPriority };
            
            var request = new UpdateCardRequest(card.Title, card.Description, newPriority, card.Status, card.DueDate, null, card.AssignedToId);
            var updated = await Api.UpdateCardAsync(card.BoardId, CardId, request);
            if (updated == null)
            {
                card = card with { Priority = originalPriority };
                errorMessage = "Failed to update priority.";
            }
        }
    }
}

@page "/cards/{CardId:guid}"
@inject ApiServiceClient Api
@inject NavigationManager Navigate
@inject AppState State
@using MetaFlow.Contracts.Cards
@using MetaFlow.Contracts.Comments
@using MetaFlow.Contracts.Attachments

@if (card == null)
{
    <p>Loading...</p>
}
else
{
    <div class="container">
        <div class="mb-4">
             <h3>@card.Title</h3>
             <small class="text-muted">In column: @card.ColumnId</small>
        </div>

        <div class="row">
            <div class="col-md-8">
                <!-- Description -->
                <div class="mb-4">
                     <h5>Description</h5>
                     <p>@card.Description</p>
                </div>
                
                <hr />

                <!-- Attachments -->
                <div class="mb-4">
                     <h5>Attachments</h5>
                     @if (attachments != null)
                     {
                         <ul class="list-group mb-3">
                             @foreach (var att in attachments)
                             {
                                 <li class="list-group-item d-flex justify-content-between align-items-center">
                                     <div>
                                         <a href="@att.FileUrl" target="_blank">@att.FileName</a>
                                         <br/>
                                         <small class="text-muted">@att.UploadedAt.ToShortDateString()</small>
                                     </div>
                                 </li>
                             }
                         </ul>
                     }
                     
                     <div class="card p-3">
                         <h6>Add Attachment (Mock)</h6>
                         <EditForm Model="@uploadModel" OnValidSubmit="HandleUpload">
                             <DataAnnotationsValidator />
                             <div class="mb-2">
                                 <InputText @bind-Value="uploadModel.FileName" placeholder="File Name" class="form-control" />
                             </div>
                             <div class="mb-2">
                                 <InputText @bind-Value="uploadModel.FileUrl" placeholder="File URL" class="form-control" />
                             </div>
                             <button type="submit" class="btn btn-sm btn-secondary">Add Attachment</button>
                         </EditForm>
                     </div>
                </div>

                <hr />
                
                <!-- Comments -->
                <div class="mb-4">
                     <h5>Comments</h5>
                     @if (comments != null)
                     {
                         @foreach (var comm in comments)
                         {
                             <div class="card mb-2">
                                 <div class="card-body p-2">
                                     <strong>User @comm.Username</strong> <small class="text-muted">@comm.CreatedAt</small>
                                     <p class="mb-1">@comm.Content</p>
                                 </div>
                             </div>
                         }
                     }
                     
                     <div class="mt-3">
                         <EditForm Model="@commentModel" OnValidSubmit="HandleComment">
                             <DataAnnotationsValidator />
                             <div class="mb-2">
                                 <InputTextArea @bind-Value="commentModel.Content" placeholder="Write a comment..." class="form-control" />
                             </div>
                             <button type="submit" class="btn btn-sm btn-primary">Post Comment</button>
                         </EditForm>
                     </div>
                </div>
            </div>

            <div class="col-md-4">
                <div class="card">
                    <div class="card-header">Actions</div>
                    <div class="card-body">
                          <div class="mb-3">
                              <label class="form-label">Priority</label>
                              <select class="form-select" @onchange="HandlePriorityChange" value="@card.Priority">
                                  <option value="low">Low</option>
                                  <option value="medium">Medium</option>
                                  <option value="high">High</option>
                                  <option value="urgent">Urgent</option>
                              </select>
                          </div>
                          <p>Due: @card.DueDate</p>
                         <button class="btn btn-danger w-100 mb-2" @onclick="HandleArchive">Archive</button>
                         <button class="btn btn-outline-danger w-100" @onclick="HandleDelete">Delete</button>
                    </div>
                </div>
            </div>
        </div>
    </div>
}

@code {
    [Parameter]
    public Guid CardId { get; set; }

    private CardResponse? card;
    private List<CommentResponse>? comments;
    private List<AttachmentResponse>? attachments;

    private CreateCommentViewModel commentModel = new();
    private UploadAttachmentViewModel uploadModel = new();

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        card = await Api.GetCardAsync(CardId);
        if (card != null)
        {
             comments = await Api.GetCommentsAsync(CardId);
             attachments = await Api.GetAttachmentsAsync(CardId);
        }
    }

    private async Task HandleComment()
    {
        var request = new CreateCommentRequest(commentModel.Content, null);
        var response = await Api.CreateCommentAsync(CardId, request);
        if (response != null)
        {
            commentModel = new();
            await LoadData();
        }
    }

    private async Task HandleUpload()
    {
        var request = new UploadAttachmentRequest(uploadModel.FileName, uploadModel.FileUrl, 1024, "text/plain", null);
        var response = await Api.UploadAttachmentAsync(CardId, request);
        if (response != null)
        {
            uploadModel = new();
            await LoadData();
        }
    }

    private async Task HandleArchive()
    {
        if (card == null) return;
        var success = await Api.ArchiveCardAsync(card.BoardId, CardId);
        if (success)
        {
            Navigate.NavigateTo($"/boards/{card.BoardId}");
        }
    }

    private async Task HandleDelete()
    {
        if (card == null) return;
        var success = await Api.DeleteCardAsync(card.BoardId, CardId);
        if (success)
        {
            Navigate.NavigateTo($"/boards/{card.BoardId}");
        }
    }

    private async Task HandlePriorityChange(ChangeEventArgs e)
    {
        if (card == null) return;
        var newPriority = e.Value?.ToString();
        if (!string.IsNullOrEmpty(newPriority))
        {
            var request = new UpdateCardRequest(card.Title, card.Description, newPriority, card.Status, card.DueDate, null, card.AssignedToId);
            var updated = await Api.UpdateCardAsync(card.BoardId, CardId, request);
            if (updated != null)
            {
                await LoadData();
            }
        }
    }
}

@page "/boards/{BoardId:guid}"
@inject ApiServiceClient Api
@inject NavigationManager Navigate
@using MetaFlow.Contracts.Boards
@using MetaFlow.Contracts.Columns
@using MetaFlow.Contracts.Cards

@if (board == null)
{
    <p>Loading...</p>
}
else
{
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h3>@board.Name</h3>
        <button class="btn btn-secondary" @onclick="() => showCreateColumn = !showCreateColumn">
            @(showCreateColumn ? "Cancel" : "Add Column")
        </button>
    </div>

    @if (showCreateColumn)
    {
        <div class="card p-3 mb-3">
             <EditForm Model="@createColumnModel" OnValidSubmit="HandleCreateColumn">
                <DataAnnotationsValidator />
                <div class="input-group">
                    <InputText @bind-Value="createColumnModel.Name" placeholder="Column Name" class="form-control" />
                    <button type="submit" class="btn btn-primary">Add</button>
                </div>
            </EditForm>
        </div>
    }

    <div class="d-flex overflow-auto gap-3 pb-3" style="height: calc(100vh - 150px);">
        @if (columns != null)
        {
            @foreach (var col in columns)
            {
                <div class="card flex-shrink-0" style="width: 300px; max-height: 100%;">
                    <div class="card-header font-weight-bold">
                        @col.Name
                        <span class="badge bg-secondary float-end">@col.WipLimit</span>
                    </div>
                    <div class="card-body overflow-auto">
                        @if (cards != null)
                        {
                            var colCards = cards.Where(c => c.ColumnId == col.Id).OrderBy(c => c.Position).ToList();
                            @foreach (var card in colCards)
                            {
                                <div class="card mb-2" @onclick="() => OpenCard(card.Id)" style="cursor: pointer;">
                                    <div class="card-body p-2">
                                        <h6 class="card-title mb-1">@card.Title</h6>
                                        <small class="text-muted">@card.Description</small>
                                        <div class="mt-1">
                                            <span class="badge bg-info text-dark">@card.Priority</span>
                                            @if (card.AssignedToId.HasValue)
                                            {
                                                 <span class="badge bg-secondary">User</span>
                                            }
                                        </div>
                                    </div>
                                </div>
                            }
                        }
                    </div>
                    <div class="card-footer p-2">
                         <button class="btn btn-sm btn-outline-primary w-100" @onclick="() => ShowAddCard(col.Id)">
                             + Add Card
                         </button>
                    </div>
                </div>
            }
        }
    </div>

    @if (activeColumnIdForCard != null)
    {
        <div class="modal d-block" style="background: rgba(0,0,0,0.5)">
             <div class="modal-dialog">
                  <div class="modal-content">
                       <div class="modal-header">
                            <h5 class="modal-title">Add Card</h5>
                            <button type="button" class="btn-close" @onclick="CancelAddCard"></button>
                       </div>
                       <div class="modal-body">
                           <EditForm Model="@createCardModel" OnValidSubmit="HandleCreateCard">
                                <DataAnnotationsValidator />
                                <ValidationSummary />
                                <div class="mb-3">
                                    <label>Title</label>
                                    <InputText @bind-Value="createCardModel.Title" class="form-control" />
                                </div>
                                <div class="mb-3">
                                    <label>Description</label>
                                    <InputTextArea @bind-Value="createCardModel.Description" class="form-control" />
                                </div>
                                <button type="submit" class="btn btn-primary">Create</button>
                           </EditForm>
                       </div>
                  </div>
             </div>
        </div>
    }
}

@code {
    [Parameter]
    public Guid BoardId { get; set; }

    private BoardResponse? board;
    private List<ColumnListResponse>? columns;
    private List<CardListResponse>? cards;

    // Column
    private bool showCreateColumn = false;
    private CreateColumnViewModel createColumnModel = new();

    // Card
    private Guid? activeColumnIdForCard;
    private CreateCardViewModel createCardModel = new();

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        board = await Api.GetBoardAsync(BoardId);
        if (board != null)
        {
            columns = await Api.GetColumnsAsync(BoardId);
            cards = await Api.GetCardsAsync(BoardId);
        }
    }

    private async Task HandleCreateColumn()
    {
        var request = new CreateColumnRequest(createColumnModel.Name, null, "custom", 0, "default");
        var response = await Api.CreateColumnAsync(BoardId, request);
        if (response != null)
        {
            createColumnModel = new();
            showCreateColumn = false;
            await LoadData();
        }
    }

    private void ShowAddCard(Guid columnId)
    {
        createCardModel = new();
        activeColumnIdForCard = columnId;
    }

    private void CancelAddCard()
    {
        activeColumnIdForCard = null;
    }

    private async Task HandleCreateCard()
    {
        if (activeColumnIdForCard != null)
        {
             var request = new CreateCardRequest(
                 createCardModel.Title,
                 createCardModel.Description,
                 activeColumnIdForCard.Value
             );
             
             var response = await Api.CreateCardAsync(BoardId, request);
             if (response != null)
             {
                 activeColumnIdForCard = null;
                 await LoadData();
             }
        }
    }

    private void OpenCard(Guid cardId)
    {
         Navigate.NavigateTo($"/cards/{cardId}");
    }
}
